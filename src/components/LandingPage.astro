---
import HeroBullets from './HeroBullets.astro';
import StoreCtaRow from './StoreCtaRow.astro';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const googlePlayHref = `https://play.google.com/store/apps/details?id=health.bluma&hl=${lang}`;
---

<!-- Hero section -->
<section class="hero" aria-labelledby="hero-title">
  <div class="hero-content" data-animate style="--reveal-delay: 60ms;">
    <h1 id="hero-title">{t('hero.title')}</h1>
    <p class="hero-subtitle">{t('hero.subtitle')}</p>
    <HeroBullets lang={lang} />
    <StoreCtaRow iosText={t('hero.cta.ios')} googlePlayHref={googlePlayHref} />
  </div>
  <div class="hero-visual" aria-hidden="true" data-animate="scale-in" style="--reveal-delay: 140ms;">
    <img src="/assets/images/hero-image.png" alt="Bluma app homescreen" style="width: 100%; height: auto;" />
  </div>
</section>

<!-- Features section -->
<section id="features" aria-labelledby="features-title">
  <div class="section-head" data-animate>
    <h2 id="features-title">{t('features.title')}</h2>
  </div>
  <div class="feature-showcase" data-animate style="--reveal-delay: 80ms;">
    <div class="feature-visual">
      <img id="feature-image" src="/assets/images/tracking.png" alt="Feature preview" />
      <div class="feature-pagination" id="feature-pagination"></div>
    </div>
    <div class="feature-list">
      <article class="feature-item active" data-image="/assets/images/tracking.png">
        <div class="icon" aria-hidden="true">
          <img src="/assets/icons/calendar.svg" alt="" width="24" height="24" />
        </div>
        <div>
          <h3>{t('feature1.title')}</h3>
          <p>{t('feature1.desc')}</p>
        </div>
      </article>
      <article class="feature-item" data-image="/assets/images/stats.png">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#ffdceb,#ffc2d9);">
          <img src="/assets/icons/spot.svg" alt="" width="24" height="24" />
        </div>
        <div>
          <h3>{t('feature2.title')}</h3>
          <p>{t('feature2.desc')}</p>
        </div>
      </article>
      <article class="feature-item" data-image="/assets/images/app-lock.png">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#e8f1ff,#cfe6ff);">
          <img src="/assets/icons/lock.svg" alt="" width="24" height="24" />
        </div>
        <div>
          <h3>{t('feature3.title')}</h3>
          <p>
            <span set:html={t('feature3.desc')} />
          </p>
        </div>
      </article>
      <article class="feature-item" data-image="/assets/images/backup.png">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#efeaff,#ddd6ff);">
          <img src="/assets/icons/backup.svg" alt="" width="24" height="24" />
        </div>
        <div>
          <h3>{t('feature4.title')}</h3>
          <p>{t('feature4.desc')}</p>
        </div>
      </article>
      <article class="feature-item" data-image="/assets/images/reminders.png">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#ffdceb,#ffc2d9);">
          <img src="/assets/icons/star.svg" alt="" width="24" height="24" />
        </div>
        <div>
          <h3>{t('feature5.title')}</h3>
          <p>{t('feature5.desc')}</p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- Founder note -->
<section id="founder-note" aria-labelledby="founder-note-title">
  <div class="section-head" data-animate>
    <h2 id="founder-note-title">{t('founder.title')}</h2>
  </div>
  <div class="how-it-works-layout" data-animate style="--reveal-delay: 80ms;">
    <div class="how-it-works-visual">
      <img src="/assets/images/portrait.png" alt="Maribel Ferreira, creator of Bluma" style="width: 70%; height: auto;" />
    </div>
    <div class="founder-note-container">
      <div class="founder-note-content">
        <p>{t('founder.note1')}</p>
        <p>{t('founder.note2')}</p>
      </div>
      <div class="founder-role">
        <p><strong>{t('founder.name')}</strong></p>
        <p>{t('founder.role')}</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQs section -->
<section id="faqs" class="faq" aria-labelledby="faq-title">
  <div class="section-head" data-animate>
    <h2 id="faq-title">{t('faq.title')}</h2>
  </div>
  <div class="faq-list" data-animate style="--reveal-delay: 80ms;">
    <details class="faq-item">
      <summary>
        <span class="faq-question">{t('faq.q1')}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{t('faq.a1')}</p>
      </div>
    </details>

    <details class="faq-item">
      <summary>
        <span class="faq-question">{t('faq.q2')}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{t('faq.a2')}</p>
      </div>
    </details>

    <details class="faq-item">
      <summary>
        <span class="faq-question">{t('faq.q3')}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{t('faq.a3')}</p>
        <p>{t('faq.a3.p2')}</p>
      </div>
    </details>

    <details class="faq-item">
      <summary>
        <span class="faq-question">{t('faq.q4')}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{t('faq.a4.p1')}</p>
        <p>{t('faq.a4.p2')}</p>
      </div>
    </details>

    <details class="faq-item">
      <summary>
        <span class="faq-question">{t('faq.q5')}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
      </summary>
      <div class="faq-answer">
        <p>{t('faq.a5')}</p>
      </div>
    </details>
  </div>
</section>

<!-- CTA section -->
<section id="cta" class="cta-section" aria-labelledby="cta-title">
  <div class="cta-card" data-animate="scale-in">
    <div class="cta-copy">
      <h2 id="cta-title">{t('cta.title')}</h2>
      <p class="cta-subhead">{t('cta.subhead')}</p>
    </div>
    <StoreCtaRow iosText={t('cta.ios')} googlePlayHref={googlePlayHref} />
  </div>
</section>

<!-- Scripts -->
<script>
  (() => {
    if (window.matchMedia('(max-width: 640px)').matches) return;

    const featureItems = document.querySelectorAll('.feature-item');
    const featureImage = document.getElementById('feature-image') as HTMLImageElement | null;
    const pagination = document.getElementById('feature-pagination');

    if (!featureImage || !pagination || featureItems.length === 0) return;

    featureItems.forEach((_, index) => {
      const dot = document.createElement('button');
      dot.className = 'pagination-dot';
      dot.setAttribute('aria-label', `Go to feature ${index + 1}`);
      if (index === 0) dot.classList.add('active');
      dot.addEventListener('click', () => setActiveFeature(index));
      pagination.appendChild(dot);
    });

    const dots = pagination.querySelectorAll('.pagination-dot');

    function setActiveFeature(index: number) {
      featureItems.forEach((i) => i.classList.remove('active'));
      dots.forEach((d) => d.classList.remove('active'));
      featureItems[index].classList.add('active');
      dots[index].classList.add('active');
      featureImage.src = (featureItems[index] as HTMLElement).dataset.image!;
    }

    featureItems.forEach((item, index) => {
      item.addEventListener('click', () => setActiveFeature(index));
    });
  })();

  (() => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animated = Array.from(document.querySelectorAll<HTMLElement>('[data-animate]'));
    if (animated.length === 0) return;

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      animated.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          (entry.target as HTMLElement).classList.add('is-visible');
          io.unobserve(entry.target);
        }
      },
      {
        root: null,
        threshold: 0.15,
        rootMargin: '0px 0px -10% 0px',
      },
    );

    animated.forEach((el) => io.observe(el));
  })();
</script>

