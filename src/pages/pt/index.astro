---
import Layout from '../../layouts/Layout.astro';
import HeroBullets from '../../components/HeroBullets.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'pt';
const t = useTranslations(lang);
---

<Layout
  title="Bluma — Rastreador de ciclo que fica no teu dispositivo"
  description="Bluma é uma app gratuita de rastreamento menstrual com privacidade em primeiro lugar. Os teus dados ficam no teu dispositivo. Sem registos, sem anúncios, sem rastreamento."
  lang={lang}
  canonicalPath="/"
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-content">
      <h1 id="hero-title">{t('hero.title')}</h1>
      <HeroBullets lang={lang} />
      <div class="cta-row">
        <a class="cta google" href="https://play.google.com/store/apps/details?id=health.bluma&hl=pt" aria-label="Obtém o Bluma no Google Play">
          <img src="/assets/images/google-play-badge.svg" alt="Disponível no Google Play" />
        </a>
        <a class="cta-helper ios-notify" href="#">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6V11c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
          {t('hero.cta.ios')}
        </a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img src="/assets/images/hero-image.png" alt="Bluma app homescreen" style="width: 100%; height: auto;" />
    </div>
  </section>

  <section id="features" style="margin-top: 32px;" aria-labelledby="features-title">
    <div class="section-head">
      <h2 id="features-title">{t('features.title')}</h2>
    </div>
    <div class="feature-showcase">
      <div class="feature-visual">
        <img id="feature-image" src="/assets/images/tracking.png" alt="Feature preview" />
        <div class="feature-pagination" id="feature-pagination"></div>
      </div>
      <div class="feature-list">
        <article class="feature-item active" data-image="/assets/images/tracking.png">
          <div class="icon" aria-hidden="true">
            <img src="/assets/icons/calendar.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.track.title')}</h3>
            <p>{t('features.track.desc')}</p>
          </div>
        </article>
        <article class="feature-item" data-image="/assets/images/symptom-tracking.png">
          <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#ffdceb,#ffc2d9);">
            <img src="/assets/icons/mood.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.symptoms.title')}</h3>
            <p>{t('features.symptoms.desc')}</p>
          </div>
        </article>
        <article class="feature-item" data-image="/assets/images/stats.png">
          <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#e8f1ff,#cfe6ff);">
            <img src="/assets/icons/stats.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.stats.title')}</h3>
            <p>{t('features.stats.desc')}</p>
          </div>
        </article>
        <article class="feature-item" data-image="/assets/images/backup.png">
          <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#efeaff,#ddd6ff);">
            <img src="/assets/icons/backup.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.backup.title')}</h3>
            <p>{t('features.backup.desc')}</p>
          </div>
        </article>
        <article class="feature-item" data-image="/assets/images/reminders.png">
          <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#ffdceb,#ffc2d9);">
            <img src="/assets/icons/notifications.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.reminders.title')}</h3>
            <p>{t('features.reminders.desc')}</p>
          </div>
        </article>
        <article class="feature-item" data-image="/assets/images/app-lock.png">
          <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#e8f1ff,#cfe6ff);">
            <img src="/assets/icons/lock.svg" alt="" width="24" height="24" />
          </div>
          <div>
            <h3>{t('features.biometric.title')}</h3>
            <p>{t('features.biometric.desc')}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="benefits" aria-labelledby="benefits-title">
    <div class="section-head">
      <h2 id="benefits-title">{t('benefits.title')}</h2>
    </div>
    <div class="benefits">
      <div class="benefit">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#dff6ff,#bde6ff);">
          <img src="/assets/icons/security.svg" alt="" width="24" height="24" />
        </div>
        <h3>{t('benefits.privacy.title')}</h3>
        <p>{t('benefits.privacy.desc')}</p>
      </div>
      <div class="benefit">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#ffe8f1,#ffd3e6);">
          <img src="/assets/icons/phone.svg" alt="" width="24" height="24" />
        </div>
        <h3>{t('benefits.ondevice.title')}</h3>
        <p>{t('benefits.ondevice.desc')}</p>
      </div>
      <div class="benefit">
        <div class="icon" aria-hidden="true" style="background: linear-gradient(180deg,#efeaff,#ddd6ff);">
          <img src="/assets/icons/code.svg" alt="" width="24" height="24" />
        </div>
        <h3>{t('benefits.opensource.title')}</h3>
        <p>
          <span set:html={t('benefits.opensource.desc')} />
        </p>
      </div>
    </div>
  </section>

  <section id="founder-note" aria-labelledby="founder-note-title">
    <div class="section-head">
      <h2 id="founder-note-title">{t('founder.title')}</h2>
    </div>
    <div class="how-it-works-layout">
      <div class="how-it-works-visual">
        <img src="/assets/images/portrait.png" alt="Maribel Ferreira, criadora do Bluma" style="width: 70%; height: auto;" />
      </div>
      <div class="founder-note-container">
        <div class="founder-note-content">
          <p>{t('founder.note1')}</p>
          <p>{t('founder.note2')}</p>
        </div>
        <div class="founder-role">
          <p><strong>{t('founder.name')}</strong></p>
          <p>{t('founder.role')}</p>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="faq" aria-labelledby="faq-title">
    <div class="section-head">
      <h2 id="faq-title">{t('faq.title')}</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>
          <span class="faq-question">{t('faq.q1')}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="faq-answer">
          <p>{t('faq.a1')}</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>
          <span class="faq-question">{t('faq.q2')}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="faq-answer">
          <p>{t('faq.a2')}</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>
          <span class="faq-question">{t('faq.q3')}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="faq-answer">
          <p>{t('faq.a3')}</p>
        </div>
      </details>

      <details class="faq-item">
        <summary>
          <span class="faq-question">{t('faq.q4')}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg class="icon-plus" viewBox="0 0 24 24" fill="none">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <svg class="icon-minus" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="faq-answer">
          <p>{t('faq.a4')}</p>
        </div>
      </details>
    </div>
  </section>

  <section id="cta" class="cta-section" aria-labelledby="cta-title">
    <div class="cta-card">
      <div class="cta-copy">
        <h2 id="cta-title">{t('cta.title')}</h2>
        <p class="cta-subhead">{t('cta.subhead')}</p>
      </div>
      <div class="cta-row">
        <a class="cta google" href="https://play.google.com/store/apps/details?id=health.bluma&hl=pt" aria-label="Obtém o Bluma no Google Play">
          <img src="/assets/images/google-play-badge.svg" alt="Disponível no Google Play" />
        </a>
        <p class="cta-helper">{t('cta.ios')}</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  const featureItems = document.querySelectorAll('.feature-item');
  const featureImage = document.getElementById('feature-image') as HTMLImageElement;
  const pagination = document.getElementById('feature-pagination')!;

  featureItems.forEach((item, index) => {
    const dot = document.createElement('button');
    dot.className = 'pagination-dot';
    dot.setAttribute('aria-label', `Funcionalidade ${index + 1}`);
    if (index === 0) dot.classList.add('active');
    dot.addEventListener('click', () => setActiveFeature(index));
    pagination.appendChild(dot);
  });

  const dots = pagination.querySelectorAll('.pagination-dot');

  function setActiveFeature(index: number) {
    featureItems.forEach((i) => i.classList.remove('active'));
    dots.forEach((d) => d.classList.remove('active'));
    featureItems[index].classList.add('active');
    dots[index].classList.add('active');
    featureImage.src = (featureItems[index] as HTMLElement).dataset.image!;
  }

  featureItems.forEach((item, index) => {
    item.addEventListener('click', () => setActiveFeature(index));
  });
</script>
