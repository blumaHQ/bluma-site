---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath?: string;
}

const { title, description, lang, canonicalPath = '/' } = Astro.props;

const siteUrl = 'https://bluma.health';
const canonicalUrl = `${siteUrl}${lang === 'en' ? canonicalPath : `/${lang}${canonicalPath}`}`;

const alternates = [
  { lang: 'en', href: `${siteUrl}${canonicalPath}` },
  { lang: 'pt', href: `${siteUrl}/pt${canonicalPath}` },
  { lang: 'es', href: `${siteUrl}/es${canonicalPath}` },
  { lang: 'x-default', href: `${siteUrl}${canonicalPath}` },
];

const ogImage = `${siteUrl}/assets/images/og-image.png`;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <script is:inline>
      (function () {
        const root = document.documentElement;

        const ua = navigator.userAgent || '';
        const platform = navigator.platform || '';

        const isAndroid = /Android/i.test(ua);
        const isAppleMobile =
          /iPhone|iPad|iPod/i.test(ua) ||
          (platform === 'MacIntel' && (navigator.maxTouchPoints || 0) > 1);

        if (isAndroid) root.classList.add('os-android');
        else if (isAppleMobile) root.classList.add('os-ios');
        else root.classList.add('os-other');
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />

    {alternates.map(({ lang: l, href }) => (
      <link rel="alternate" hreflang={l} href={href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Bluma" />
    <meta property="og:locale" content={lang === 'pt' ? 'pt_PT' : lang === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MobileApplication',
      name: 'Bluma',
      operatingSystem: 'ANDROID',
      applicationCategory: 'HealthApplication',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      url: siteUrl,
      description,
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  
    <!-- MailerLite Universal -->
    <script is:inline>
      (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
      .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
      n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
      (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', '2297568');
    </script>
    <!-- End MailerLite Universal -->
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <div class="grain" aria-hidden="true"></div>
    <Header lang={lang} />
    <main id="main" class="container">
      <slot />
    </main>
    <Footer lang={lang} currentYear={currentYear} />
  </body>
</html>
